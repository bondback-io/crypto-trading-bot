    "@solana/web3.js": "^1.98.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "typescript": "^5.7.3"
  },
