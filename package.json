{
  "name": "solana-smart-money-copy-bot",
  "version": "1.1.4",
  "updatedAt": "2026-07-23T00:10:00.000Z",
  "description": "Solana smart money copy trading bot for Pump.fun launches and migrations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "prestart": "node -e \"require('fs').accessSync('dist/index.js')\"",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "fly:launch": "fly launch --no-deploy",
    "fly:deploy": "fly deploy",
    "fly:logs": "fly logs",
    "fly:status": "fly status",
    "fly:ssh": "fly ssh console",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop solana-copy-bot",
    "pm2:restart": "npm run build && pm2 restart solana-copy-bot --update-env",
    "pm2:logs": "pm2 logs solana-copy-bot",
    "pm2:delete": "pm2 delete solana-copy-bot"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "solana",
    "copy-trading",
    "pump.fun",
    "jupiter"
  ],
