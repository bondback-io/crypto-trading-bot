# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env for local runs.
# Fly.io: use `fly secrets set KEY=value` (see README → Deploy on Fly.io).
# Render: set keys in the Dashboard → Environment.
# Never commit real keys or a filled .env file.
# ═══════════════════════════════════════════════════════════════════════════

# --- Required ---
# Primary Solana RPC (Helius / QuickNode recommended for production)
RPC_URL=https://api.mainnet-beta.solana.com

# Server (Render injects PORT automatically — leave unset on Render)
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# paper | live — start with paper on Render
TRADING_MODE=paper

# --- Recommended for production ---
# Comma-separated fallback RPCs
RPC_FALLBACKS=

# --- Live trading only (never commit) ---
# Preferred live key env var
TRADING_WALLET_1=
# Optional second / burner wallet
TRADING_WALLET_2=
# Aliases used if TRADING_WALLET_1 is empty (main wallet)
PRIVATE_KEY=
WALLET_PRIVATE_KEY=

# --- Optional APIs (strongly recommended for Discover Smart Wallets) ---
# Without these keys, discovery falls back to Kolscan + curated lists only.
#
# GMGN: create a key at https://gmgn.ai/ai (upload a public key if prompted).
# On Render, also whitelist the service egress IPv4 in the GMGN dashboard if available.
# Prefer the OpenAPI host when you have a key:
GMGN_API_KEY=
GMGN_BASE_URL=https://api.gmgn.ai
# Optional alternate OpenAPI host
# GMGN_OPENAPI_URL=https://api.gmgn.ai
#
# Birdeye: create a key at https://birdeye.so → Data API / BDS Dashboard → Security.
# Free/standard plans cover token overview + trending; trader gainers may need a paid tier.
BIRDEYE_API_KEY=
BIRDEYE_BASE_URL=https://public-api.birdeye.so
BIRDEYE_CACHE_MS=90000

# Prefer "all" so Kolscan/Dex still fill results when GMGN/Birdeye are down
WALLET_DISCOVERY_SOURCE=all
WALLET_DISCOVERY_CACHE_MS=300000

# Early Pump.fun curve priority
EARLY_CURVE_MAX_PCT=35
MIN_EARLY_BIRDEYE_SM=40
EARLY_CURVE_MIN_WALLETS=1

# Advanced profit-taking (optional overrides)
# PROFIT_STRATEGY_ENABLED=true
# PROFIT_TAKE_INITIAL_PCT=100
# PROFIT_PARTIAL_AT=80
# PROFIT_PARTIAL_SELL_PCT=50
# PROFIT_TRAIL_AFTER=150
# PROFIT_TRAIL_PCT=25
# PROFIT_BAG_PCT=30
# PROFIT_RISK_ADJUST=true

# Optional CORS for external API clients (dashboard is same-origin by default)
# CORS_ORIGIN=https://your-frontend.example.com

# Jito / MEV (optional — live)
JITO_ENABLED=false
JITO_BLOCK_ENGINE=https://mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=10000
JITO_UUID=
ENABLE_MEV_PROTECTION=false

# Dashboard settings + wallets persist under data/ (bot-settings.json, wallets.json).
# Fly.io: volume at /data (see fly.toml) — set automatically via DATA_DIR=/data
# Render Free wipes the filesystem every deploy — upgrade + disk, or use Fly.
# DATA_DIR=/data
DATA_DIR=
